APP_NAME=EVOORION
APP_ENV=production
APP_KEY=                          # generated by: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.evoorion.osama-ali.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=             # from Hostinger hPanel → Databases
DB_USERNAME=             # from Hostinger hPanel → Databases
DB_PASSWORD=             # from Hostinger hPanel → Databases

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.osama-ali.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=            # your Hostinger email
MAIL_PASSWORD=            # your Hostinger email password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="invest@osama-ali.com"
MAIL_FROM_NAME="EVOORION"

# CORS — comma-separated, no spaces
CORS_ALLOWED_ORIGINS=https://evoorion.osama-ali.com,https://admin.evoorion.osama-ali.com

SANCTUM_STATEFUL_DOMAINS=evoorion.osama-ali.com,admin.evoorion.osama-ali.com

FRONTEND_URL=https://evoorion.osama-ali.com

# Cloudinary (copy from your local .env)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (update redirect URIs to production URLs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.evoorion.osama-ali.com/api/v1/auth/social/google/callback
